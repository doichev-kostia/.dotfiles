" .ideavimrc is a configuration file for IdeaVim plugin. It uses
"   the same commands as the original .vimrc configuration.
" You can find a list of commands here: https://jb.gg/h38q75
" Find more examples here: https://jb.gg/share-ideavimrc

set number relativenumber
set ideajoin
set idearefactormode=keep
set scrolloff = 5
set tabstop = 4
set softtabstop = 4
set shiftwidth = 4
set expandtab = true

" Do incremental searching.
set incsearch

" Don't use Ex mode, use Q for formatting.
map Q gq

if s:MaySet('backspace')
  set backspace=indent,eol,start
endif

let mapleader = " "

unmap <leader><leader>

" Remap for dealing with word wrap
nnoremap <expr> k v:count == 0 ? 'gk' : 'k'
nnoremap <expr> j v:count == 0 ? 'gj' : 'j'

"  move the selected line up/down
vnoremap K :m '<-2<CR>gv=gv
vnoremap J :m '>+1<CR>gv=gv

" Automatically center the half-page jumps
nnoremap <C-d> <C-d>zz
nnoremap <C-u> <C-u>zz

" Map <leader>y to yank in normal and visual mode to the clipboard
nnoremap <leader>y "+y
vnoremap <leader>y "+y

" Map <leader>Y to yank the entire line in normal mode to the clipboard
nnoremap <leader>Y "+yy

" shift + shift -> IdeaVim: Track Action Ids
map gr <Action>(FindUsages)
nmap gi <Action>(GotoImplementation)
map <leader>gs <Action>(FileStructurePopup)

nnoremap <silent> gh :action ShowErrorDescription<CR>
xnoremap <silent> gh <Esc>:action ShowErrorDescription<CR>

" next diagnostic
nnoremap <silent> dn :<C-u>action GotoNextError<CR>

" previous diagnostic
nnoremap <silent> dp :<C-u>action GotoPreviousError<CR>


" Easier split navigation (no need for Ctrl+W prefix)
nnoremap <C-h> <C-w>h
nnoremap <C-j> <C-w>j
nnoremap <C-k> <C-w>k
nnoremap <C-l> <C-w>l

" Vim-style folding in IdeaVim
noremap zc :action CollapseRegion<CR>
noremap zo :action ExpandRegion<CR>
noremap zC :action CollapseRegionRecursively<CR>
noremap zO :action ExpandRegionRecursively<CR>
noremap za :action ToggleFoldRegion<CR>
noremap zM :action CollapseAllRegions<CR>
noremap zR :action ExpandAllRegions<CR>

" Focus previous split pane (left/up)
" nnoremap <leader>tp :action PrevSplitter<CR>

" Focus next split pane (right/down)
" nnoremap <leader>tn :action NextSplitter<CR>

" --- Enable IdeaVim plugins https://jb.gg/ideavim-plugins

" Highlight copied text
Plug 'machakann/vim-highlightedyank'
" Commentary plugin
Plug 'tpope/vim-commentary'
" Surround plugin
Plug 'tpope/vim-surround'
" Repeat plugin
Plug 'tpope/vim-repeat'
" Easymotion plugin
Plug 'easymotion/vim-easymotion'
" Git plugin
Plug 'tpope/vim-fugitive'
" Commentary
Plug 'tpope/vim-commentary'
" Scope plugin
Plug 'wellle/context.vim'

let g:context_enabled = 1:


" Nerd tree plugin for file system explorer navigation using h,j,k,l
set NERDTree
let g:NERDTreeMapActivateNode = 'l'

" OCaml
set rtp^="/Users/panenco/.opam/default/share/ocp-indent/vim"
